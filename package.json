{
  "name": "converter-app",
  "version": "1.0.1",
  "description": "Конвертер изображений на Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir"
  },
  "keywords": [
    "electron",
    "converter",
    "image"
  ],
  "author": "VeelZacks",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.veelzacks.converterapp",
    "productName": "ConverterApp",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "sharp": "^0.34.5"
  }
}
